		<region region-id="4616" left="30" top="2786.25" width="363" height="24" align-x="34.5" align-y="2796" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="0" margin-right="0" text-indent="inherit" text-align="left" list-style-type="inherit" tabs="inherit">
					<f size="11">La fila </f>
					<f size="11">
						<b>
							<i>n</i>
						</b>
					</f>
					<f size="11"> de μ esta dada por la columna </f>
					<f size="11">
						<b>
							<i>n</i>
						</b>
					</f>
					<f size="11"> de la traspuesta de μ. La operación de vecindad esta dada por:</f>
				</p>
			</text>
		</region>
		<region region-id="4618" left="42" top="2830.5" width="340.5" height="23.25" align-x="81" align-y="2850" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:function>
						<ml:id xml:space="preserve">OP</ml:id>
						<ml:boundVars>
							<ml:id xml:space="preserve">x</ml:id>
							<ml:id xml:space="preserve">y</ml:id>
						</ml:boundVars>
					</ml:function>
					<ml:apply>
						<ml:plus/>
						<ml:apply>
							<ml:plus/>
							<ml:apply>
								<ml:mult/>
								<ml:apply>
									<ml:matcol/>
									<ml:parens>
										<ml:apply>
											<ml:transpose/>
											<ml:id xml:space="preserve">μ</ml:id>
										</ml:apply>
									</ml:parens>
									<ml:real>0</ml:real>
								</ml:apply>
								<ml:apply>
									<ml:matcol/>
									<ml:apply>
										<ml:id xml:space="preserve">SubM</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve">x</ml:id>
											<ml:id xml:space="preserve">y</ml:id>
										</ml:sequence>
									</ml:apply>
									<ml:real>0</ml:real>
								</ml:apply>
							</ml:apply>
							<ml:apply>
								<ml:mult/>
								<ml:apply>
									<ml:matcol/>
									<ml:parens>
										<ml:apply>
											<ml:transpose/>
											<ml:id xml:space="preserve">μ</ml:id>
										</ml:apply>
									</ml:parens>
									<ml:real>1</ml:real>
								</ml:apply>
								<ml:apply>
									<ml:matcol/>
									<ml:apply>
										<ml:id xml:space="preserve">SubM</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve">x</ml:id>
											<ml:id xml:space="preserve">y</ml:id>
										</ml:sequence>
									</ml:apply>
									<ml:real>1</ml:real>
								</ml:apply>
							</ml:apply>
						</ml:apply>
						<ml:apply>
							<ml:mult/>
							<ml:apply>
								<ml:matcol/>
								<ml:parens>
									<ml:apply>
										<ml:transpose/>
										<ml:id xml:space="preserve">μ</ml:id>
									</ml:apply>
								</ml:parens>
								<ml:real>2</ml:real>
							</ml:apply>
							<ml:apply>
								<ml:matcol/>
								<ml:apply>
									<ml:id xml:space="preserve">SubM</ml:id>
									<ml:sequence>
										<ml:id xml:space="preserve">x</ml:id>
										<ml:id xml:space="preserve">y</ml:id>
									</ml:sequence>
								</ml:apply>
								<ml:real>2</ml:real>
							</ml:apply>
						</ml:apply>
					</ml:apply>
				</ml:define>
			</math>
