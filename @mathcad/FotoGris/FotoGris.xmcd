					<ml:apply>
						<ml:id xml:space="preserve">READ_IMAGE</ml:id>
						<ml:str xml:space="preserve">Lenna.jpg</ml:str>
					</ml:apply>
				</ml:define>
			</math>
			<rendering item-idref="4"/>
		</region>
